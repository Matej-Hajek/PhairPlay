<?xml version="1.0" encoding="utf-8"?>
<!--
    btn_control_selector.xml — Background for primary control buttons (Start/Stop/Restart).
    Shows a blue background on focus, accent-pressed on press, and surface when idle.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_blue" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_blue_pressed" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background_surface_elevated" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
