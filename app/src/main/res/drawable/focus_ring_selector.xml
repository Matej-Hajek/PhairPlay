<?xml version="1.0" encoding="utf-8"?>
<!--
    focus_ring_selector.xml — Focus state drawable for all interactive TV elements.

    Applies a visible blue border when a view has D-pad focus.
    This is the primary focus indicator for PhairPlay's TV UI.
    All interactive views (buttons, cards, toggles) must use this as their background.

    Usage in layout XML:
        android:background="@drawable/focus_ring_selector"
    Or as foreground for cards:
        android:foreground="@drawable/focus_ring_selector"
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state: blue ring with slight background brightening -->
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/background_surface_elevated" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="3dp" android:color="@color/focus_ring" />
                    <corners android:radius="12dp" />
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Pressed state: slightly dimmed -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_blue_pressed" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Normal state: surface card background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background_surface" />
            <corners android:radius="12dp" />
        </shape>
    </item>

</selector>
